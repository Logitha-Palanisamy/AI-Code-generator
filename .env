# FastAPI Configuration
PROJECT_NAME="AI Code Generation Agent"
API_V1_STR="/api/v1"
SECRET_KEY="super-secret-dev-only-key-dont-use-in-production-12345"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
