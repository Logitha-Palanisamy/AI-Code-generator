# FastAPI Configuration
PROJECT_NAME="AI Code Generation Agent"
API_V1_STR="/api/v1"
SECRET_KEY="replace-this-with-a-very-secure-random-key-for-jwt"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
# Use sqlite:///./app.db for local development, postgresql+psycopg://user:password@localhost:5432/db for prod
DATABASE_URL="sqlite:///./app.db"

# Redis & Celery Configuration
REDIS_URL="redis://localhost:6379/0"

# AI Provider Configuration
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# Sandbox Configuration
SANDBOX_TIMEOUT_SECONDS=60
SANDBOX_MAX_MEM_MB=512
SANDBOX_MAX_CPUS=1
